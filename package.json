{
  "name": "spatial-garden",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file-if-exists=.env --env-file-if-exists=.env.local server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "multer": "^2.1.1",
    "three": "^0.184.0",
    "uuid": "^14.0.0"
  }
}
